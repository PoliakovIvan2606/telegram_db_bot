TELEGRAM_BOT_TOKEN=
# Локально — localhost; в docker compose URL к БД переопределяется в docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_bot
OPENROUTER_API_KEY=

# Optional
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536
CHAT_MODEL=openai/gpt-4o-mini
SUMMARY_MODEL=google/gemini-2.0-flash-001
# Модель с audio input: https://openrouter.ai/models?input_modalities=audio
# Голос Telegram — OGG; для OpenAI-моделей нужен ffmpeg (OGG→WAV) в PATH
VOICE_TRANSCRIPTION_MODEL=openai/gpt-4o-audio-preview
YANDEX_DISK_WEBDAV_USER=
YANDEX_DISK_WEBDAV_PASSWORD=
# Comma-separated Telegram user IDs; leave empty for any user
ALLOWED_USER_IDS=
RAG_TOP_K=5
CHUNK_MAX_CHARS=900
MAP_CHUNK_CHARS=12000
# ru alone avoids extra YouTube subtitle requests (429); add en if needed: ru,en
SUBTITLE_LANGS=ru
